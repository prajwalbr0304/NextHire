# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Large data (organiser property — not committed)
candidates.jsonl
candidates.jsonl.gz
*.jsonl

# Precomputed artifacts (regenerated by precompute.py). Large intermediates stay
# ignored, but the SMALL frozen retrieval index (JD-specific shortlist +
# similarities, ~1 MB) and its row-aligned candidate ids ARE committed so the
# ranking step reproduces inside the Stage-3 sandbox within the 5-minute budget
# without rebuilding (regenerate with: python precompute.py --backend lsa --gzip).
artifacts/*.pkl
artifacts/*.npy
artifacts/*.bin
artifacts/onnx/
!artifacts/retriever.pkl
!artifacts/retriever.pkl.gz
!artifacts/candidate_ids.pkl
!artifacts/candidate_ids.pkl.gz

# Audit trail (regenerated per run; keep the folder)
compliance/audit_trail/*.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Allow submission to be inspected but it's reproducible
# submission.csv
