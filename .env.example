# =============================================================================
# Redrob Ranker — environment template. Copy to `.env` and fill in real values.
# The backend reads this file automatically (searched upward from api/).
# =============================================================================

# --- Supabase (stores every ranking task + its results & shortlists) ---------
# Project URL and keys from Supabase → Project Settings → API.
# The backend uses the SERVICE ROLE key (server-side only; bypasses RLS).
# Run `redrob-ranker-v2/supabase_schema.sql` once in the Supabase SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- NextAI assistant (LLM over the live rank list) --------------------------
# Add your key here when ready — the assistant turns on automatically.
# provider = openai | gemini | anthropic
NEXTAI_PROVIDER=openai
NEXTAI_API_KEY=
# Optional: defaults are sensible per provider.
#   openai   -> gpt-4o-mini      anthropic -> claude-3-5-sonnet-20241022
#   gemini   -> gemini-1.5-flash
NEXTAI_MODEL=gpt-4o-mini
# Optional, OpenAI-compatible providers only (Groq / OpenRouter / Together / local):
#   Groq        https://api.groq.com/openai/v1
#   OpenRouter  https://openrouter.ai/api/v1
# NEXTAI_BASE_URL=https://api.openai.com/v1

# --- Candidate dataset (optional override) -----------------------------------
# REDROB_CANDIDATES=C:\path\to\candidates.jsonl
