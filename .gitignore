# ===== Python =====
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# ===== Node / Next.js (web/) =====
node_modules/
.next/
out/
*.tsbuildinfo
npm-debug.log*

# ===== Large datasets (organiser property — never commit) =====
*.jsonl
*.jsonl.gz
candidates.jsonl

# ===== Precomputed model artifacts (regenerated by precompute.py) =====
# Large intermediates stay ignored, but the SMALL frozen retrieval index (~1 MB)
# and its row-aligned candidate ids ARE committed so Stage-3 reproduces fast
# (regenerate with: python precompute.py --backend lsa --gzip).
artifacts/*.pkl
artifacts/*.npy
artifacts/*.bin
artifacts/onnx/
!artifacts/retriever.pkl
!artifacts/retriever.pkl.gz
!artifacts/candidate_ids.pkl
!artifacts/candidate_ids.pkl.gz

# ===== Audit trail (regenerated per run) =====
compliance/audit_trail/*.json

# ===== Generated submissions / exports =====
submission_smoke.csv
*_smoke*.xlsx

# ===== Logs & runtime scratch =====
*.log
*.err
_run.*
_api.*

# ===== Secrets / local env =====
.env
.env.local
*.env.local

# ===== OS / editor junk =====
.DS_Store
__MACOSX/
Thumbs.db
.idea/
.vscode/
